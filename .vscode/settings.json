{
  "C_Cpp.default.compileCommands": "${workspaceFolder}/compile_commands.json",
  "C_Cpp.default.configurationProvider": "platformio.platformio-ide",
  "dotnet.defaultSolution": "tools/configurator/LuefterConfigurator.sln",
  "dotnet.server.trace": "Trace",
  "dotnet.testWindow.disableBuildOnRefresh": false,
