  "dotnet.testWindow.discoveryTimeoutInSec": 900,
  "dotnet.testWindow.enableTestExplorerDiff": true,
  "razor.trace": "Verbose",
  "csharp.debug.debugConsoleVerbosity": "verbose",
  "csharp.debug.hotReloadVerbosity": "diagnostic"
}
