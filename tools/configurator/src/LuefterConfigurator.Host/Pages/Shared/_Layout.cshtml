<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Luefterklappen Konfigurator</title>
    <link rel="icon" type="image/svg+xml" href="/brand/luefterklappen-logo-mark.svg" />
    <link rel="apple-touch-icon" sizes="256x256" href="/brand/luefterklappen-icon-256.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <main role="main">
        @RenderBody()
    </main>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
